.neo-theme-neo-light .portal-news-pulls-component .neo-badge {
  background-color: #eff1f3;
  border: 1px solid rgba(0, 0, 0, 0.1);
  color: #24292f;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-state-badge {
  color: #ffffff;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-state-badge.neo-state-open {
  background-color: #2da44e;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-state-badge.neo-state-merged {
  background-color: #8250df;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-state-badge.neo-state-closed {
  background-color: #cf222e;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-review-state {
  color: #ffffff;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-review-state.neo-review-approved {
  background-color: #2da44e;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-review-state.neo-review-changes {
  background-color: #cf222e;
}
.neo-theme-neo-light .portal-news-pulls-component .neo-badge.neo-review-state.neo-review-neutral {
  background-color: #eff1f3;
  color: #24292f;
}