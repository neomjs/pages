.neo-theme-neo-dark .portal-news-pulls-component .neo-badge {
  background-color: #21262d;
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #c9d1d9;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-state-badge {
  color: #ffffff;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-state-badge.neo-state-open {
  background-color: #3fb950;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-state-badge.neo-state-merged {
  background-color: #a371f7;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-state-badge.neo-state-closed {
  background-color: #f85149;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-review-state {
  color: #ffffff;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-review-state.neo-review-approved {
  background-color: #3fb950;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-review-state.neo-review-changes {
  background-color: #f85149;
}
.neo-theme-neo-dark .portal-news-pulls-component .neo-badge.neo-review-state.neo-review-neutral {
  background-color: #21262d;
  color: #c9d1d9;
}