.neo-grid-view {
  height: 100%;
  min-width: 0;
  overflow-anchor: none;
  overflow-x: hidden;
  overflow-y: scroll;
  position: relative;
}
.neo-grid-view:focus {
  outline: none;
}
.neo-grid-view.neo-hide-scrollbar {
  -ms-overflow-style: none; /* IE, Edge */
  scrollbar-width: none; /* Firefox */
}
.neo-grid-view.neo-hide-scrollbar::-webkit-scrollbar {
  display: none; /* Chrome, Safari, Edge */
}