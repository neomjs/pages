.neo-grid-tree-cell {
  align-items: center;
  display: flex;
  flex: 1;
  min-width: 0;
}
.neo-grid-tree-cell .neo-tree-indent {
  flex: none;
  width: calc(var(--tree-depth, 0) * var(--tree-indent, 16px));
}
.neo-grid-tree-cell .neo-tree-toggle {
  cursor: pointer;
  flex: none;
  text-align: center;
  width: 24px;
}
.neo-grid-tree-cell .neo-tree-toggle.is-leaf {
  cursor: default;
}
.neo-grid-tree-cell .neo-tree-toggle.is-collapsed::before {
  content: var(--tree-toggle-icon-collapsed);
}
.neo-grid-tree-cell .neo-tree-toggle.is-expanded::before {
  content: var(--tree-toggle-icon-expanded);
}
.neo-grid-tree-cell .neo-tree-toggle.is-leaf::before {
  content: var(--tree-toggle-icon-leaf);
}
.neo-grid-tree-cell .neo-tree-toggle::before {
  display: inline-block;
  font-family: var(--fa-style-family-classic);
  font-weight: 900;
}
.neo-grid-tree-cell .neo-tree-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}