.neo-grid-container {
  border: 1px solid var(--grid-container-border-color);
  border-spacing: 0;
  color: var(--grid-container-color);
  display: flex;
  flex-direction: column;
  font-size: var(--grid-container-font-size);
  font-weight: 400;
  height: 100%;
  line-height: 19px;
  overflow-anchor: none;
  overflow-x: hidden;
  overflow-y: clip;
  overscroll-behavior: none;
  position: relative;
  width: 100%;
}
.neo-grid-container.neo-masked {
  opacity: 0.3;
}
.neo-grid-container.neo-masked .neo-load-mask .neo-load-mask-body .fa-spinner {
  height: 3em;
  font-size: 3em;
  line-height: 3em;
}
.neo-grid-container.neo-masked .neo-load-mask .neo-load-mask-body .neo-loading-message {
  font-size: 2.5em;
}