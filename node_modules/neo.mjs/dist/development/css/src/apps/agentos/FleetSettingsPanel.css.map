.agent-panel-settings.neo-panel {
  min-height: 660px;
  min-width: 360px;
}
.agent-panel-settings.neo-panel .agent-definition-grid {
  min-height: 150px;
}
.agent-panel-settings.neo-panel .agent-definition-form {
  gap: 10px;
  padding: 12px;
}
.agent-panel-settings.neo-panel .agent-definition-form .agent-form-copy {
  display: flex;
  flex-direction: column;
  font-size: 12px;
  line-height: 1.35;
}
.agent-panel-settings.neo-panel .agent-definition-form .agent-form-copy strong {
  font-size: 13px;
}
.agent-panel-settings.neo-panel .agent-definition-form .neo-textfield {
  width: 100%;
}
.agent-panel-settings.neo-panel .agent-harness-picker,
.agent-panel-settings.neo-panel .agent-form-actions {
  background-color: transparent;
  border: 0;
  min-height: 34px;
  padding: 0;
}
.agent-panel-settings.neo-panel .agent-harness-picker {
  column-gap: 12px;
  flex-wrap: wrap;
  row-gap: 6px;
}
.agent-panel-settings.neo-panel .agent-form-actions {
  column-gap: 8px;
  flex-wrap: wrap;
  row-gap: 8px;
}
.agent-panel-settings.neo-panel .agent-form-actions .agent-lifecycle-button.neo-disabled {
  opacity: 0.45;
}
.agent-panel-settings.neo-panel .agent-status-pill {
  border: 1px solid currentColor;
  border-radius: 8px;
  display: inline-block;
  font-size: 11px;
  line-height: 1.2;
  padding: 2px 7px;
}
.agent-panel-settings.neo-panel .agent-status-pill.is-redacted, .agent-panel-settings.neo-panel .agent-status-pill.is-gated {
  color: var(--agent-state-waiting);
}
.agent-panel-settings.neo-panel .agent-status-pill.is-stored-node-side {
  color: var(--agent-state-live);
}
.agent-panel-settings.neo-panel .agent-bridge-status {
  border-left: 3px solid var(--agent-state-waiting);
  font-size: 12px;
  line-height: 1.35;
  min-height: 34px;
  padding: 7px 10px;
}
.agent-panel-settings.neo-panel .agent-bridge-status.is-error {
  border-left-color: var(--agent-accent-intervention);
  color: var(--agent-accent-intervention);
}
.agent-panel-settings.neo-panel .agent-bridge-status.is-live {
  border-left-color: var(--agent-state-live);
  color: var(--agent-state-live);
}

@media (max-width: 820px) {
  .agent-panel-settings.neo-panel {
    min-width: 280px;
  }
  .agent-panel-settings.neo-panel .agent-form-actions .neo-button {
    min-width: 40px;
  }
  .agent-panel-settings.neo-panel .agent-form-actions .agent-lifecycle-button .neo-button-text {
    display: none;
  }
}