.portal-home-parts-aitoolchain {
  background-color: transparent;
  color: var(--sem-color-text-neutral-default);
  gap: 4rem;
  padding: 6em 2em 0; /* Removing bottom padding as FooterContainer is attached */
  scroll-snap-align: start;
}
.portal-home-parts-aitoolchain .content-wrapper {
  align-items: center;
  background-color: transparent;
  display: flex;
  flex-direction: column;
  gap: 2rem;
  margin: 0 auto;
  max-width: 1200px;
  width: 100%;
}
.portal-home-parts-aitoolchain .neo-h1 {
  color: var(--portal-headline-primary) !important;
  font-family: "GT-Planar", sans-serif;
  font-size: 4rem;
  line-height: 1.1;
  margin: 0;
  text-align: center;
}
.portal-home-parts-aitoolchain .neo-h3 {
  color: var(--sem-color-text-neutral-subdued) !important;
  font-size: 1.5rem;
  line-height: 1.5;
  margin: 0;
  max-width: 800px;
  text-align: center;
}
.portal-home-parts-aitoolchain .card-container {
  background-color: transparent;
  gap: 2rem;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 2rem;
  overflow: visible;
  padding: 10px;
  width: 100%;
}
@media (max-width: 900px) {
  .portal-home-parts-aitoolchain .card-container {
    grid-template-columns: 1fr;
  }
}
.portal-home-parts-aitoolchain .agent-os-faq {
  margin-top: 2rem;
  max-width: 960px;
  width: 100%;
}
.portal-home-parts-aitoolchain .agent-os-faq h2 {
  color: var(--portal-headline-primary);
  font-family: "GT-Planar", sans-serif;
  font-size: 2rem;
  line-height: 1.2;
  margin: 0 0 1.5rem;
  text-align: center;
}
.portal-home-parts-aitoolchain .agent-os-faq .faq-list {
  display: grid;
  gap: 1.5rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}
@media (max-width: 800px) {
  .portal-home-parts-aitoolchain .agent-os-faq .faq-list {
    grid-template-columns: 1fr;
  }
}
.portal-home-parts-aitoolchain .agent-os-faq article {
  border-top: 1px solid var(--sem-color-border-subtle);
  padding-top: 1rem;
}
.portal-home-parts-aitoolchain .agent-os-faq h3 {
  color: var(--sem-color-text-neutral-default);
  font-size: 1.1rem;
  line-height: 1.35;
  margin: 0 0 0.5rem;
}
.portal-home-parts-aitoolchain .agent-os-faq p {
  color: var(--sem-color-text-neutral-subdued);
  font-size: 1rem;
  line-height: 1.6;
  margin: 0;
}