.portal-discussions-maincontainer {
  background-color: transparent;
}
.portal-discussions-maincontainer .discussion-tree-node {
  align-items: center;
  display: inline-flex;
  gap: 6px;
  max-width: 100%;
  min-width: 0;
}
.portal-discussions-maincontainer .discussion-tree-node .discussion-state-badge {
  align-items: center;
  border-radius: 50%;
  color: var(--portal-discussion-tree-state-icon-color);
  display: inline-flex;
  flex: 0 0 auto;
  height: 16px;
  justify-content: center;
  width: 16px;
}
.portal-discussions-maincontainer .discussion-tree-node .discussion-state-badge.neo-state-answered {
  background-color: var(--portal-discussion-tree-state-answered-bg);
}
.portal-discussions-maincontainer .discussion-tree-node .discussion-state-badge.neo-state-closed {
  background-color: var(--portal-discussion-tree-state-closed-bg);
}
.portal-discussions-maincontainer .discussion-tree-node .discussion-state-badge.neo-state-open {
  background-color: var(--portal-discussion-tree-state-open-bg);
}
.portal-discussions-maincontainer .discussion-tree-node .discussion-title {
  min-width: 0;
}