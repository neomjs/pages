.neo-markdown-vdom {
  overflow-y: auto;
}
.neo-markdown-vdom > * {
  content-visibility: auto;
  contain-intrinsic-size: auto 28px;
}
.neo-markdown-vdom > .neo-md-spacer {
  content-visibility: visible;
  flex-shrink: 0;
}
.neo-markdown-vdom .neo-md-code {
  overflow-x: auto;
}
.neo-markdown-vdom .neo-md-table {
  border-collapse: collapse;
}
.neo-markdown-vdom .neo-md-table th, .neo-markdown-vdom .neo-md-table td {
  border: 1px solid var(--grid-border-color, #444);
  padding: 0.3em 0.6em;
}
.neo-markdown-vdom .neo-md-quote {
  border-inline-start: 3px solid var(--blockquote-border-color, #888);
  margin: 0.5em 0;
  padding-inline: 0.8em;
}