ber} [options.sampleSize=DEFAULT_STORED_EMBEDDING_EXPORTABILITY_SAMPLE_SIZE]\n * @returns {Promise<Object>}\n */","meta":{"range":[16084,17523],"filename":"checkChromaIntegrity.mjs","lineno":524,"columnno":0,"path":"/Users/Shared/github/neomjs/pages/node_modules/neo.mjs/ai/scripts/maintenance","code":{"id":"astnode100117031","name":"exports.probeStoredEmbeddingExportability","type":"FunctionDeclaration","paramnames":[""]}},"params":[{"type":{"names":["Object"]},"name":"options"},{"type":{"names":["Object"]},"name":"options.collection"},{"type":{"names":["Number"]},"optional":true,"defaultvalue":"DEFAULT_STORED_EMBEDDING_EXPORTABILITY_SAMPLE_SIZE","name":"options.sampleSize"}],"returns":[{"type":{"names":["Promise.<Object>"]}}],"name":"probeStoredEmbeddingExportability","longname":"ai.scripts.maintenance.module:checkChromaIntegrity.probeStoredEmbeddingExportability","kind":"function","memberof":"ai.scripts.maintenance.module:checkChromaIntegrity","scope":"static","$longname":"ai.scripts.maintenance.module:checkChromaIntegrity.probeStoredEmbeddingExportability","$kind":"method","id":8598,"neoClassName":"Neo.ai.scripts.maintenance.checkChromaIntegrity"},{"comment":"/**\n * @summary Audits a Chroma collection's stored-vector dimensions — the data-integrity dimension fact-gatherer\n * the diagnostics runner imports to feed `buildDimensionConsistencyDiagnosis`. Samples up to `sampleSize`\n * stored vectors and counts those whose dimension differs from the configured `expectedDimension`. A *missing*\n * embedding is NOT a dimension mismatch — that is index-coverage's domain (`auditChromaVectorCoverage`); only a\n * present vector of the wrong length counts. Returns the producer's per-collection `samples` element shape, 1:1.\n * A probe failure surfaces as an `error` field with a zero count — it never throws into the runner.\n *\n * @param {Object} options\n * @param {Object} options.collection Chroma collection handle (`.get({ids, limit, include})`).\n * @param {String} op