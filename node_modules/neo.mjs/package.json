    ],
    "author" : "Tobias Uhlig",
    "license": "MIT",
    "bugs"   : {
        "url": "https://github.com/neomjs/neo/issues"
    },
    "homepage"       : "https://neomjs.com/",
    "devDependencies": {
        "@chroma-core/default-embed"   : "^0.1.9",
        "@fortawesome/fontawesome-free": "^7.3.0",
        "@google/generative-ai"        : "^0.24.1",
        "@modelcontextprotocol/sdk"    : "^1.29.0",
        "@playwright/test"             : "^1.61.1",
        "acorn"                        : "^8.17.0",
        "astring"                      : "^1.9.0",
        "autoprefixer"                 : "^10.5.2",
        "better-sqlite3"               : "^12.11.1",
        "chalk"                        : "^5.6.2",
        "chromadb"                     : "^3.5.0",
        "clean-webpack-plugin"         : "^4.0.0",
        "commander"                    : "^15.0.0",
        "cssnano"                      : "^7.1.9",
        "dotenv"                       : "^17.4.2",
        "envinfo"                      : "^7.21.0",
        "esbuild"                      : "^0.28.1",
        "fast-glob"                    : "^3.3.3",
        "fs-extra"                     : "^11.3.6",
        "glob"                         : "^13.0.6",
        "gray-matter"                  : "^4.0.3",
        "highlightjs-line-numbers.js"  : "^2.9.1",
        "html-minifier-terser"         : "^7.2.0",
        "husky"                        : "^9.1.7",
        "inquirer"                     : "^13.4.3",
        "js-yaml"                      : "^5.2.0",
        "jsdoc-api"                    : "^9.3.6",
        "lint-staged"                  : "^17.0.8",
        "marked"                       : "^18.0.5",
        "mermaid"                      : "^11.16.0",
        "monaco-editor"                : "0.50.0",
        "parse5"                       : "^8.0.1",
        "postcss"                      : "^8.5.16",
        "sass"                         : "^1.101.0",
        "semver"                       : "^7.8.5",
        "terser"                       : "^5.48.0",
        "url"                          : "^0.11.4",
        "webpack"                      : "^5.108.3",
        "webpack-cli"                  : "^7.1.0",
        "webpack-dev-server"           : "^5.2.3",
        "webpack-hook-plugin"          : "^1.0.7",
        "webpack-node-externals"       : "^3.0.0",
        "ws"                           : "^8.21.0",
        "yargs"                        : "^18.0.0",
        "zod"                          : "^4.4.3"
    },
    "funding": {
        "type": "GitHub Sponsors",
        "url" : "https://github.com/sponsors/tobiu"
    },
    "lint-staged": {
        "*": [
            "node ./buildScripts/util/check-whitespace.mjs"
        ],
        "*.mjs": [
            "node ./buildScripts/util/check-shorthand.mjs",
            "node ./buildScripts/util/check-jsdoc-types.mjs",
            "node ./buildScripts/util/check-ticket-archaeology.mjs",
            "node ./buildScripts/util/check-block-alignment.mjs --staged"
        ],
        "test/**/*.mjs": [
            "node ./buildScripts/util/check-aiconfig-test-mutation.mjs"
        ]
    }
}
