# See http://help.github.com/ignore-files/ for more about ignoring files.

/package-lock.json

# dependencies
/node_modules/*

# neo.mjs
!/node_modules/neo.mjs
/node_modules/neo.mjs/package-lock.json
!/node_modules/neo.mjs/*
!/node_modules/neo.mjs/dist/development/*
!/node_modules/neo.mjs/dist/production/*

# neo.mjs agent-OS substrate + repo meta (ships in the npm tarball, not part of the deployed body)
/node_modules/neo.mjs/.agents
/node_modules/neo.mjs/.claude
/node_modules/neo.mjs/.codex
/node_modules/neo.mjs/.gemini
/node_modules/neo.mjs/.github
/node_modules/neo.mjs/.husky
/node_modules/neo.mjs/.neo-ai-data
/node_modules/neo.mjs/ai

# font awesome
/node_modules/neo.mjs/node_modules/*
!/node_modules/neo.mjs/node_modules/@fortawesome
!/node_modules/neo.mjs/node_modules/@fortawesome/*
!/node_modules/@fortawesome
!/node_modules/highlightjs-line-numbers.js
!/node_modules/marked
!/node_modules/mermaid
!/node_modules/monaco-editor

# highlight.js
!/node_modules/neo.mjs/node_modules/highlightjs-line-numbers.js
!/node_modules/neo.mjs/node_modules/highlightjs-line-numbers.js/*

# marked
!/node_modules/neo.mjs/node_modules/marked/lib/marked.esm.js

# mermaid
!/node_modules/neo.mjs/node_modules/mermaid
/node_modules/neo.mjs/node_modules/mermaid/*
!/node_modules/neo.mjs/node_modules/mermaid/dist
/node_modules/neo.mjs/node_modules/mermaid/dist/*
!/node_modules/neo.mjs/node_modules/mermaid/dist/mermaid.min.js

# monaco-editor
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/base
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/base/*
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/basic-languages/javascript/javascript.js
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/basic-languages/markdown/markdown.js
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/basic-languages/typescript/typescript.js
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/editor/editor.main.css
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/editor/editor.main.js
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/editor/editor.main.nls.js
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/language
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/language/*
!/node_modules/neo.mjs/node_modules/monaco-editor/min/vs/loader.js

# siesta
!/node_modules/neo.mjs/node_modules/siesta-lite/resources/css/*
!/node_modules/neo.mjs/node_modules/siesta-lite/siesta-all.js

# IDEs and editors
/.idea
.project
.classpath
*.launch
.settings/

#System Files
.DS_Store
Thumbs.db
